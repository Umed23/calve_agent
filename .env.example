# =============================================================
# CALVE Voice Agent — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Clinic ────────────────────────────────────────────────────
CLINIC_ID=clinic_001
CLINIC_NAME=Sharma Clinic

# ── Voice / Language ──────────────────────────────────────────
LANGUAGE=hi
STT_ENGINE=artpark
TTS_ENGINE=facebook

# ── Twilio (Optional — leave blank to disable) ─────────────────
USE_TWILIO=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Server (Render sets PORT automatically) ───────────────────
PORT=8000
HOST=0.0.0.0

# ── Local Voice Agent only ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
STT_MODEL_SIZE=small
# STT_LANGUAGE=hi
